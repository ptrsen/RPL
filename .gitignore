# =========================
# Cargo / Rust
# =========================
# Ignore all Cargo build artifacts
/target/
**/target/

# Ignore Cargo.lock in workspaces (keep if you want reproducible builds)
# Cargo.lock

# Ignore temporary Cargo files
**/*.rs.bk
**/*.rs~

# =========================
# Rustlings
# =========================
# Build artifacts and cache
rustlings/target/
rustlings/.rustlings/

# Backup or temp files in exercises
rustlings/exercises/**/*.rs.bk
rustlings/exercises/**/*.rs~

# =========================
# Chapter projects
# =========================
# Ignore per-chapter target folders
chapter*/target/

# Optional: ignore generated binaries (if any)
chapter*/src/bin/*.exe
chapter*/src/bin/*.out
chapter*/src/bin/*

# =========================
# DevContainer / VS Code
# =========================
.vscode/
.devcontainer/.vscode/
.devcontainer/.cache/
*.code-workspace

# =========================
# OS / System files
# =========================
.DS_Store
Thumbs.db
*.swp
*~

# =========================
# Logs and temporary files
# =========================
*.log
*.tmp